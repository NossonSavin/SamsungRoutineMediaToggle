<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="toggle_media"
        android:enabled="true"
        android:shortcutShortLabel="@string/shortcut_toggle_media"
        android:icon="@mipmap/ic_launcher">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.example.mediacontroller"
            android:targetClass="com.example.mediacontroller.MainActivity" />
        <capability-binding android:key="actions.intent.CONTROL_MEDIA" />
    </shortcut>

    <capability android:name="actions.intent.CONTROL_MEDIA">
        <intent
            android:action="android.intent.action.MAIN"
            android:targetPackage="com.example.mediacontroller"
            android:targetClass="com.example.mediacontroller.MainActivity">
            <parameter
                android:name="mediaPerformance.mediaControlIntent"
                android:key="controlType"
                android:value="PLAY_PAUSE"/>
        </intent>
    </capability>
</shortcuts>
